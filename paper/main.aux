\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Finite-size pseudo-thresholds $p^*$ (WER = 0.10 crossing) for bivariate bicycle codes. Seed = 12345, 200{,}000 shots per point, BP-OSD (OSD order=10). Uncertainties are 95\% bootstrap CIs.}}{3}{table.1}\protected@file@percent }
\newlabel{tab:thresholds}{{1}{3}{Finite-size pseudo-thresholds $p^*$ (WER = 0.10 crossing) for bivariate bicycle codes. Seed = 12345, 200{,}000 shots per point, BP-OSD (OSD order=10). Uncertainties are 95\% bootstrap CIs}{table.1}{}}
