\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces WER vs.\ erasure rate for bivariate bicycle codes (solid lines, $N=144$--$1296$) and surface code baselines. Dashed lines: erasure-aware MWPM surface codes ($N=288$--$2592$, $K=2$). Dotted lines: uninformed MWPM surface codes ($N=288$--$1152$, $K=2$, three sizes). Error bars show 95\% Wilson confidence intervals. All BB code curves cross WER = 0.10 at $p^* = 0.37$--$0.47$; erasure-aware surface codes cross at $p^* = 0.41$--$0.46$.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:wer_curves}{{4}{6}{WER vs.\ erasure rate for bivariate bicycle codes (solid lines, $N=144$--$1296$) and surface code baselines. Dashed lines: erasure-aware MWPM surface codes ($N=288$--$2592$, $K=2$). Dotted lines: uninformed MWPM surface codes ($N=288$--$1152$, $K=2$, three sizes). Error bars show 95\% Wilson confidence intervals. All BB code curves cross WER = 0.10 at $p^* = 0.37$--$0.47$; erasure-aware surface codes cross at $p^* = 0.41$--$0.46$}{figure.4}{}}
